# Copy to ../.env.local (project root) or set in docker-compose environment.
# For local Postgres container, docker-compose overrides DATABASE_URL automatically.

DATABASE_URL=postgresql://dev:devpwd@postgres:5432/ai_learning
JWT_SECRET=change_me
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=ai-learning

# Frontend (browser calls host-mapped backend port)
VITE_BACKEND_URL=http://localhost:4000
